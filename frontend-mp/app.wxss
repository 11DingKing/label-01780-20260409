/** 全局样式 - 温暖色系 **/
page {
  --primary: #E85D3A;
  --primary-light: #F5A623;
  --bg: #FFF8F5;
  --card-bg: #FFFFFF;
  --text: #333;
  --text-secondary: #666;
  --text-hint: #999;
  --border: #eee;
  --radius: 12rpx;
  --shadow: 0 4rpx 24rpx rgba(232, 93, 58, 0.08);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  background: var(--bg);
  color: var(--text);
  font-size: 28rpx;
}

.container {
  padding: 24rpx 32rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.btn-primary:active {
  opacity: 0.9;
}

.urgency-high { color: #E85D3A; }
.urgency-mid { color: #F5A623; }
.urgency-low { color: #7ED321; }

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}
