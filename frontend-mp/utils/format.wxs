/**
 * WXS 格式化工具 — 可在 wxml 模板中直接调用
 */

/**
 * 格式化时间: "2026-02-22T11:49:23" → "2026-02-22 11:49"
 */
function fmtTime(str) {
  if (!str) return '';
  var s = str + '';
  // 处理 ISO 格式
  var idx = s.indexOf('T');
  if (idx > -1) {
    var date = s.substring(0, idx);
    var time = s.substring(idx + 1, idx + 6);
    return date + ' ' + time;
  }
  // 已经是正常格式则截取到分钟
  if (s.length > 16) return s.substring(0, 16);
  return s;
}

/**
 * 取昵称首字作为头像文字
 */
function avatarText(name) {
  if (!name) return '匿';
  return name.substring(0, 1);
}

module.exports = {
  fmtTime: fmtTime,
  avatarText: avatarText
};
