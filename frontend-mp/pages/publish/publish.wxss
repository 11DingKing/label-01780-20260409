/* 3步流程指示器 */
.step-bar { display: flex; align-items: flex-start; justify-content: center; padding: 20rpx 32rpx 12rpx; }
.step { display: flex; flex-direction: column; align-items: center; width: 120rpx; }
.step-num { width: 44rpx; height: 44rpx; border-radius: 50%; background: #ddd; color: #fff; font-size: 24rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; }
.step-active .step-num { background: #E85D3A; }
.step-text { font-size: 20rpx; color: #999; margin-top: 6rpx; white-space: nowrap; }
.step-active .step-text { color: #E85D3A; font-weight: 600; }
.step-line { width: 48rpx; height: 3rpx; background: #ddd; margin: 20rpx 4rpx 0; flex-shrink: 0; }
.line-active { background: #E85D3A; }

.label { display: block; margin-bottom: 12rpx; color: var(--text-secondary); font-size: 26rpx; font-weight: 600; }
.textarea { width: 100%; min-height: 200rpx; padding: 16rpx; box-sizing: border-box; background: var(--bg); border-radius: 8rpx; margin-top: 8rpx; }
.images { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 16rpx; }
.img-wrap { position: relative; width: 160rpx; height: 160rpx; }
.thumb { width: 100%; height: 100%; border-radius: 8rpx; }
.del { position: absolute; top: 0; right: 0; width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.5); color: #fff; text-align: center; line-height: 40rpx; border-radius: 50%; font-size: 32rpx; }
.add-img { width: 160rpx; height: 160rpx; border: 2rpx dashed var(--border); border-radius: 8rpx; display: flex; align-items: center; justify-content: center; color: var(--text-hint); font-size: 26rpx; }
.submit-btn { margin-top: 48rpx; width: 100%; }

/* 位置 */
.location-row { display: flex; align-items: center; gap: 16rpx; margin-top: 12rpx; }
.addr-text { flex: 1; font-size: 26rpx; color: var(--text-secondary); }
.hint-text { color: var(--text-hint); }
.anon-switch { transform: scale(0.7); }
.anon-label { font-size: 22rpx; color: var(--text-hint); }
.btn-small { font-size: 24rpx; padding: 8rpx 24rpx; background: var(--primary); color: #fff; border-radius: 8rpx; line-height: 1.4; }

/* 紧急程度 */
.urgency-row { display: flex; gap: 16rpx; margin-top: 12rpx; }
.urgency-opt { flex: 1; text-align: center; padding: 16rpx; border-radius: 8rpx; background: var(--bg); font-size: 28rpx; transition: all 0.2s; border: 2rpx solid transparent; box-sizing: border-box; }
.urgency-opt:active { transform: scale(0.96); }
.active-high { background: #FDECEA; color: #E85D3A; font-weight: 600; border: 2rpx solid #E85D3A; }
.active-mid { background: #FFF3E0; color: #F5A623; font-weight: 600; border: 2rpx solid #F5A623; }
.active-low { background: #E8F5E9; color: #7ED321; font-weight: 600; border: 2rpx solid #7ED321; }

/* 联系人 */
.contact-section { margin-top: 16rpx; border-top: 1rpx solid var(--border, #eee); padding-top: 16rpx; }
.contact-header { display: flex; justify-content: space-between; align-items: center; padding: 8rpx 0; }
.contact-toggle-label { font-size: 26rpx; color: var(--text-secondary); }
.arrow { font-size: 28rpx; color: var(--text-hint); }
.contact-list { margin-top: 12rpx; }
.contact-item { display: flex; justify-content: space-between; align-items: center; padding: 16rpx; background: var(--bg); border-radius: 8rpx; margin-bottom: 8rpx; transition: all 0.2s; border: 2rpx solid transparent; box-sizing: border-box; }
.contact-item:active { transform: scale(0.98); }
.contact-item.selected { background: #FDECEA; border: 2rpx solid var(--primary); }
.contact-name { font-size: 26rpx; color: var(--text); }
.contact-check { color: var(--primary); font-weight: 600; }
.empty-hint { margin-top: 12rpx; font-size: 24rpx; color: var(--text-hint); }
.link { color: var(--primary); font-size: 26rpx; }
