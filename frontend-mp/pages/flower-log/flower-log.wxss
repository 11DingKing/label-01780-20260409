.row { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.type { font-weight: 600; }
.amount.inc { color: var(--primary); }
.amount.dec { color: var(--text-hint); }
.remark, .time { font-size: 24rpx; color: var(--text-hint); display: block; }
.empty, .loading { text-align: center; padding: 48rpx; }
