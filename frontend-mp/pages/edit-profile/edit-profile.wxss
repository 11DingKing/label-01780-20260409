.avatar-section { text-align: center; padding: 24rpx; }
.avatar { width: 160rpx; height: 160rpx; border-radius: 50%; display: block; margin: 0 auto 12rpx; }
.avatar-hint { font-size: 24rpx; color: var(--primary); }
.form-row { display: flex; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid var(--border); }
.form-row:last-child { border-bottom: none; }
.form-label { width: 160rpx; font-size: 28rpx; color: var(--text-secondary); }
.form-input { flex: 1; font-size: 28rpx; }
.privacy-row { justify-content: space-between; }
.save-btn { margin-top: 48rpx; width: 100%; }
