.container { height: 100vh; background: #FFF8F5; display: flex; flex-direction: column; }
.swiper { flex: 1; }
.step-page {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 100%; padding: 0 48rpx; text-align: center;
}
.step-emoji { font-size: 120rpx; margin-bottom: 40rpx; }
.step-title { font-size: 40rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }
.step-desc { font-size: 28rpx; color: #666; line-height: 1.8; max-width: 560rpx; }
.btn-start {
  margin-top: 60rpx; background: #E85D3A; color: #fff; border: none;
  border-radius: 48rpx; padding: 20rpx 80rpx; font-size: 32rpx; font-weight: 500;
}
.bottom-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 48rpx 60rpx;
}
.skip { font-size: 28rpx; color: #999; }
.dots { display: flex; gap: 12rpx; }
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: rgba(232,93,58,0.2); }
.dot.active { background: #E85D3A; width: 32rpx; border-radius: 8rpx; }

.privacy-link { display: block; margin-top: 24rpx; font-size: 24rpx; color: #E85D3A; text-decoration: underline; }
