.header-card .hint { color: var(--text-hint); font-size: 24rpx; }
.help-item { margin-bottom: 24rpx; }
.help-meta { display: flex; align-items: center; margin-bottom: 16rpx; }
.avatar { width: 64rpx; height: 64rpx; border-radius: 50%; margin-right: 16rpx; }
.avatar-text { width: 64rpx; height: 64rpx; border-radius: 50%; margin-right: 16rpx; background: linear-gradient(135deg, #E85D3A, #F5A623); color: #fff; font-size: 28rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.meta-right { flex: 1; display: flex; flex-direction: column; }
.nick-row { display: flex; align-items: center; gap: 8rpx; }
.nick { font-weight: 600; color: var(--text); }
.badge-icon { width: 28rpx; height: 28rpx; }
.badge-label { font-size: 20rpx; color: #E85D3A; font-weight: 600; }
.time { font-size: 24rpx; color: var(--text-hint); margin-top: 4rpx; }
.urgency { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; background: rgba(0,0,0,0.06); }
.urgency-high { background: #FDECEA; color: #E85D3A; }
.urgency-mid { background: #FFF3E0; color: #F5A623; }
.urgency-low { background: #E8F5E9; color: #4CAF50; }
.content-preview { display: block; color: var(--text-secondary); font-size: 28rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.addr { margin-top: 8rpx; font-size: 24rpx; color: var(--text-hint); }
.empty, .loading, .nomore { text-align: center; padding: 48rpx; color: var(--text-hint); }

/* 悬浮发布按钮 - 视觉突出 */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 140rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #E85D3A 0%, #FF7043 100%);
  color: #fff;
  padding: 24rpx 36rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(232,93,58,0.45);
  z-index: 50;
  animation: fabPulse 2s ease-in-out infinite;
}
.fab-icon {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}
.fab-text {
  font-size: 28rpx;
  font-weight: 600;
}
.fab:active { opacity: 0.85; transform: scale(0.96); }

@keyframes fabPulse {
  0%, 100% { box-shadow: 0 8rpx 32rpx rgba(232,93,58,0.45); }
  50% { box-shadow: 0 12rpx 48rpx rgba(232,93,58,0.65); }
}

/* 功能引导浮层 */
.guide-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6); z-index: 999;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.guide-bubble {
  background: #fff; border-radius: 16rpx; padding: 24rpx 32rpx;
  margin-bottom: 32rpx; max-width: 80%;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
  position: relative;
}
.guide-bubble::after {
  content: ''; position: absolute; bottom: -16rpx; left: 50%;
  transform: translateX(-50%);
  border: 8rpx solid transparent; border-top-color: #fff;
}
.guide-text { font-size: 28rpx; color: #333; line-height: 1.6; }
.guide-bubble-fab { position: absolute; right: 40rpx; bottom: 220rpx; }
.guide-bubble-list { position: absolute; top: 280rpx; left: 32rpx; right: 32rpx; }
.guide-bubble-tab { position: absolute; bottom: 20rpx; left: 32rpx; right: 32rpx; }
.guide-bubble-tab::after { border-top-color: #fff; bottom: -16rpx; }
.guide-dismiss {
  position: absolute; top: 120rpx; left: 0; right: 0;
  text-align: center;
}
.guide-dismiss-text {
  font-size: 32rpx; color: #fff; font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}
