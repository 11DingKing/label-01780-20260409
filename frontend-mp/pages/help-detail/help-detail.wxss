/* 基础 */
.help-meta { display: flex; align-items: center; margin-bottom: 16rpx; }
.avatar-text { width: 64rpx; height: 64rpx; border-radius: 50%; margin-right: 16rpx; background: linear-gradient(135deg, #E85D3A, #F5A623); color: #fff; font-size: 28rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.meta-right { flex: 1; min-width: 0; }
.nick-row { display: flex; align-items: center; gap: 8rpx; }
.nick { font-weight: 600; font-size: 30rpx; }
.badge-icon { width: 32rpx; height: 32rpx; }
.badge-label { font-size: 22rpx; color: #E85D3A; font-weight: 600; }
.urgency { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; display: inline-block; margin-top: 6rpx; }
.urgency-high { background: #FDECEA; color: #E85D3A; }
.urgency-mid { background: #FFF3E0; color: #F5A623; }
.urgency-low { background: #E8F5E9; color: #4CAF50; }
.content { display: block; color: #333; font-size: 30rpx; line-height: 1.7; white-space: pre-wrap; margin-top: 16rpx; }
.addr { margin-top: 16rpx; color: #666; font-size: 26rpx; }
.time { display: block; margin-top: 12rpx; font-size: 24rpx; color: #999; }
.images { display: flex; flex-wrap: wrap; gap: 12rpx; }
.img { max-width: 100%; border-radius: 8rpx; }

/* 底部固定互动栏 */
.bottom-actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex;
  background: #fff; border-top: 1rpx solid #eee;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 50;
}
.act-item,
.act-share-btn {
  width: 33.33%;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: 18rpx 0 12rpx;
  margin: 0;
  background: none; border: none;
  font-size: 32rpx; line-height: 1;
  box-sizing: border-box;
}
.act-item::after,
.act-share-btn::after { display: none; }
.act-icon { font-size: 40rpx; }
.act-label { font-size: 22rpx; color: #666; margin-top: 6rpx; display: block; }
.act-done { opacity: 0.4; }
.act-tip .act-label { color: #E85D3A; font-weight: 600; }

/* 弹出动画 */
@keyframes popIn { 0% { transform: scale(1); } 50% { transform: scale(1.15); } 100% { transform: scale(1); } }
.anim-pop { animation: popIn 0.5s ease; }

/* 小红花飘落 */
.flower-rain { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 999; overflow: hidden; }
@keyframes flowerFall { 0% { transform: translateY(-60rpx) rotate(0deg); opacity: 1; } 100% { transform: translateY(100vh) rotate(360deg); opacity: 0; } }
.flower-item { position: absolute; top: -60rpx; font-size: 48rpx; animation: flowerFall 2.5s ease-in forwards; }

/* 打赏面板 */
.tip-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); z-index: 100; }
.tip-panel { position: fixed; bottom: 0; left: 0; width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); z-index: 101; transform: translateY(100%); transition: transform 0.3s ease; box-sizing: border-box; }
.tip-panel.show { transform: translateY(0); }
.tip-title { font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 24rpx; }
.tip-amounts { display: flex; flex-wrap: wrap; gap: 16rpx; }
.tip-amount { width: calc(33.33% - 12rpx); text-align: center; padding: 20rpx 0; background: #FFF8F5; border-radius: 12rpx; font-size: 30rpx; font-weight: 600; color: #333; box-sizing: border-box; border: 2rpx solid transparent; }
.tip-amount:active { opacity: 0.7; }
.tip-amount.selected { background: #FDECEA; color: #E85D3A; border-color: #E85D3A; }
.tip-custom { display: flex; align-items: center; margin-top: 24rpx; gap: 12rpx; }
.tip-label { font-size: 26rpx; color: #666; white-space: nowrap; }
.tip-input { flex: 1; border: 2rpx solid #eee; border-radius: 8rpx; padding: 12rpx 16rpx; font-size: 28rpx; }
.tip-unit { font-size: 26rpx; color: #666; }
.tip-info { margin-top: 16rpx; font-size: 24rpx; color: #E85D3A; }
.tip-confirm { margin-top: 24rpx; width: 100%; }
.loading { text-align: center; padding: 48rpx; }

/* 联系人信息 */
.section-label { display: block; font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 12rpx; }
.contact-info { background: #FFF8F5; border-radius: 8rpx; padding: 16rpx; }
.contact-detail { display: block; font-size: 28rpx; color: #555; margin-bottom: 8rpx; }
.contact-phone { display: block; font-size: 26rpx; color: #888; }
