/* Tab 切换 */
.tab-bar { display: flex; background: #fff; border-radius: 12rpx; margin-bottom: 16rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; color: #666; transition: all 0.2s; }
.tab-active { color: #E85D3A; font-weight: 600; border-bottom: 4rpx solid #E85D3A; }

/* 系统记录 */
.type { font-weight: 600; display: block; margin-bottom: 8rpx; }
.content-preview { font-size: 26rpx; color: var(--text-secondary); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.time { font-size: 24rpx; color: var(--text-hint); margin-top: 8rpx; display: block; }

/* 用户经历 */
.btn-add { margin-bottom: 16rpx; background: #FFF8F5; color: #E85D3A; border: 2rpx dashed #E85D3A; border-radius: 12rpx; font-size: 28rpx; }
.note-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.note-title { font-size: 30rpx; font-weight: 600; color: #333; flex: 1; }
.note-actions { display: flex; gap: 16rpx; }
.note-edit { font-size: 24rpx; color: #E85D3A; }
.note-del { font-size: 24rpx; color: #999; }
.note-content { font-size: 26rpx; color: #555; line-height: 1.6; display: block; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.4); z-index: 100; }
.modal-panel { position: fixed; bottom: 0; left: 0; width: 100%; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); z-index: 101; transform: translateY(100%); transition: transform 0.3s ease; box-sizing: border-box; }
.modal-panel.show { transform: translateY(0); }
.modal-title { font-size: 34rpx; font-weight: 600; display: block; margin-bottom: 24rpx; }
.modal-input { width: 100%; border: 2rpx solid #eee; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.modal-textarea { width: 100%; min-height: 200rpx; border: 2rpx solid #eee; border-radius: 8rpx; padding: 16rpx; font-size: 26rpx; box-sizing: border-box; }
.modal-btn { margin-top: 24rpx; width: 100%; }

.empty, .loading { text-align: center; padding: 48rpx; color: #999; font-size: 26rpx; }
